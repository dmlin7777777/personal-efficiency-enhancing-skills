{# ── Resume Tailor v3.0 — Jinja2 Layout Template ──
  This template wraps the rendered HTML body in a complete HTML document
  with inline CSS for portability and A4 print settings.
  Variables injected by renderer.py: css_inline, body_html, role_title, etc.
-#}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ role_title }} | Resume Tailor</title>
<style>
{{ css_inline }}
</style>
</head>
<body>

<div class="page-container">
{{ body_html }}
</div>

{# ── Render metadata (hidden from print) ── #}
<div class="no-print" style="margin-top: 20pt; font-size: 7.5pt; color: #9ca3af; text-align: center;">
  Generated by Resume Tailor v3.0 | {{ generated_at[:19] if generated_at else '' }}
  {%- if company %} | {{ company }}{% endif -%}
</div>

</body>
</html>
