{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "snapshot-schema-v1.json",
  "title": "Resume Tailor v3 Context Snapshot",
  "description": "State protocol for pseudo multi-agent blackboard architecture. Four-layer: Facts(read-only) / Decisions(persistent+nuance) / Outputs(volatile).",
  "type": "object",
  "required": [
    "_meta",
    "jd_facts",
    "user_decisions",
    "expert_outputs"
  ],
  "properties": {
    "_meta": {
      "type": "object",
      "description": "Session metadata and orchestration control.",
      "required": [
        "version",
        "session_id",
        "status",
        "last_updated"
      ],
      "properties": {
        "version": {
          "type": "string",
          "const": "1.1",
          "description": "1.0 initial, 1.1 added nuance_buffer + conversation_history."
        },
        "session_id": {
          "type": "string",
          "pattern": "^\\d{8}_[a-z0-9_]+$"
        },
        "status": {
          "type": "string",
          "enum": [
            "initialized",
            "scout_complete",
            "match_review",
            "phase_3_adjustment",
            "writer_draft",
            "audit_in_progress",
            "complete",
            "archived",
            "rollback_requested"
          ]
        },
        "last_updated": {
          "type": "string",
          "format": "date-time"
        },
        "current_node": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            null,
            "scout",
            "architect_writer",
            "architect_quantify",
            "architect_wording",
            "auditor_sincerity",
            "auditor_compliance",
            "auditor_interview",
            "renderer"
          ]
        },
        "rollback_from": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            null,
            "phase_4_audit",
            "phase_3_adjustment",
            "phase_2_match"
          ]
        },
        "error_log": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "node": {
                "type": "string"
              },
              "code": {
                "type": "string",
                "enum": [
                  "JSON_PARSE_FAIL",
                  "TOOL_ERROR",
                  "LLM_TIMEOUT",
                  "ROLLBACK_TRIGGERED",
                  "USER_ABORT"
                ]
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "timestamp",
              "node",
              "code",
              "message"
            ]
          },
          "default": []
        },
        "conversation_history": {
          "type": "array",
          "description": "Rolling summary of recent turns. Injected into each new node prompt by engine.py.",
          "items": {
            "type": "object",
            "required": [
              "turn_number",
              "node",
              "summary"
            ],
            "properties": {
              "turn_number": {
                "type": "integer"
              },
              "node": {
                "type": "string"
              },
              "summary": {
                "type": "string",
                "description": "1-2 sentence summary per turn."
              },
              "key_outputs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "maxItems": 10,
          "default": []
        }
      }
    },
    "jd_facts": {
      "type": "object",
      "description": "Layer 1: Script-determined facts. READ-ONLY after init.",
      "required": [
        "raw_jd_text",
        "role_title",
        "company_name",
        "region",
        "role_level",
        "hard_requirements",
        "soft_requirements"
      ],
      "properties": {
        "raw_jd_text": {
          "type": "string"
        },
        "role_title": {
          "type": "string"
        },
        "company_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "type": "string",
          "enum": [
            "north_america",
            "uk_ireland",
            "dach",
            "east_asia",
            "global",
            "unknown"
          ]
        },
        "role_level": {
          "type": "string",
          "enum": [
            "campus",
            "social",
            "senior",
            "executive",
            "internship",
            "unknown"
          ]
        },
        "hard_requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "category",
              "value",
              "met"
            ],
            "properties": {
              "category": {
                "type": "string"
              },
              "value": {
                "type": "string"
              },
              "met": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "evidence_source": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "soft_requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "text",
              "category"
            ],
            "properties": {
              "text": {
                "type": "string"
              },
              "category": {
                "type": "string"
              }
            }
          }
        },
        "capability_clusters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "market_notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "ats_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "user_decisions": {
      "type": "object",
      "description": "Layer 2: User-confirmed results + semantic buffer.",
      "properties": {
        "resume_source_path": {
          "type": "string"
        },
        "kept_experiences": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "label"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "position_order": {
                "type": "integer"
              },
              "metadata": {
                "type": "object",
                "properties": {
                  "company_name": {
                    "type": "string"
                  },
                  "job_title": {
                    "type": "string"
                  },
                  "department": {
                    "type": "string"
                  },
                  "date_range": {
                    "type": "string"
                  },
                  "location": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "removed_experiences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "new_entries": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "default": []
        },
        "confirmed_quantifications": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "confirmed_wording_changes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "regional_adaptations": {
          "type": "object",
          "properties": {
            "photo_action": {
              "type": "string"
            },
            "personal_info_removals": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "tone_level": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          }
        },
        "user_preferences": {
          "type": "object",
          "properties": {
            "output_format": {
              "type": "string",
              "enum": [
                "docx",
                "pdf",
                "markdown",
                "html"
              ],
              "default": "docx"
            },
            "page_limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3,
              "default": 1
            },
            "include_shadow_resume": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "nuance_buffer": {
          "type": "array",
          "description": "Semantic buffer: unstructured but important context passed between nodes. Not every fact fits a structured field; this is the escape hatch.",
          "items": {
            "type": "object",
            "required": [
              "source_node",
              "timestamp",
              "content"
            ],
            "properties": {
              "source_node": {
                "type": "string",
                "enum": [
                  "scout",
                  "architect_writer",
                  "architect_quantify",
                  "architect_wording",
                  "auditor_sincerity",
                  "auditor_compliance",
                  "auditor_interview"
                ]
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "content": {
                "type": "string",
                "description": "Free-text note (1-3 sentences). Examples: user pivoting to ML; user hesitant on X; JD suggests scrappy startup vibe."
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Searchable tags: culture, quantification_hint, red_flag, user_sentiment, etc."
              },
              "target_nodes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Empty = broadcast to all future nodes."
              }
            }
          },
          "default": []
        }
      }
    },
    "expert_outputs": {
      "type": "object",
      "description": "Layer 3: Expert outputs. VOLATILE - can be overwritten.",
      "properties": {
        "scout_report": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "summary": {
              "type": "string"
            },
            "key_findings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "risk_flags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "match_matrix": {
          "type": [
            "object",
            "null"
          ]
        },
        "writer_draft_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "audit_report": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "overall_risk_level": {
              "type": "string",
              "enum": [
                "LOW",
                "MEDIUM",
                "HIGH"
              ]
            },
            "major_issues": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "minor_issues": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "compliance_check": {
              "type": "object"
            },
            "mock_interview_questions": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "delivery_package": {
              "type": [
                "object",
                "null"
              ]
            }
          }
        }
      }
    }
  }
}